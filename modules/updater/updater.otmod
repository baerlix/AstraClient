Module
  name: updater
  description: Updates client
  author: Mateuzkl / Equipe Skyyzyy
  website: https://github.com/Mateuzkl/AstraClient
  reloadable: false
  scripts: [ updater ]
  dependencies: [ client_locales, client_styles, client_textedit ]
  @onUnload: Updater.terminate()

  load-later:
    - client_background
